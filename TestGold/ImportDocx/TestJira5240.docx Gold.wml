uot;dxa&quot; /&gt;&lt;w:bottom w:w=&quot;0&quot; w:type=&quot;dxa&quot; /&gt;&lt;w:right w:w=&quot;108&quot; w:type=&quot;dxa&quot; /&gt;&lt;/w:tblCellMar&gt;&lt;/w:tblPr&gt;&lt;/w:style&gt;&lt;w:style w:type=&quot;list&quot; w:default=&quot;on&quot; w:styleId=&quot;NoList&quot;&gt;&lt;w:name w:val=&quot;No List&quot; /&gt;&lt;w:semiHidden /&gt;&lt;/w:style&gt;&lt;/w:styles&gt;&lt;w:docPr&gt;&lt;w:view w:val=&quot;print&quot; /&gt;&lt;w:zoom w:percent=&quot;100&quot; /&gt;&lt;w:proofState w:grammar=&quot;clean&quot; /&gt;&lt;w:attachedTemplate w:val=&quot;&quot; /&gt;&lt;w:stylePaneFormatFilter w:val=&quot;3F01&quot; /&gt;&lt;w:defaultTabStop w:val=&quot;720&quot; /&gt;&lt;w:characterSpacingControl w:val=&quot;DontCompress&quot; /&gt;&lt;w:validateAgainstSchema /&gt;&lt;w:compat&gt;&lt;w:breakWrappedTables /&gt;&lt;w:snapToGridInCell /&gt;&lt;w:wrapTextWithPunct /&gt;&lt;w:useAsianBreakRules /&gt;&lt;w:useWord2002TableStyleRules /&gt;&lt;/w:compat&gt;&lt;/w:docPr&gt;&lt;w:body&gt;&lt;wx:sect&gt;&lt;w:p&gt;&lt;m:oMathPara&gt;&lt;m:oMath /&gt;&lt;/m:oMathPara&gt;&lt;/w:p&gt;&lt;w:sectPr&gt;&lt;w:pgSz w:w=&quot;12240&quot; w:h=&quot;15840&quot; /&gt;&lt;w:pgMar w:top=&quot;1440&quot; w:right=&quot;1800&quot; w:bottom=&quot;1440&quot; w:left=&quot;1800&quot; w:header=&quot;708&quot; w:footer=&quot;708&quot; w:gutter=&quot;0&quot; /&gt;&lt;w:cols w:space=&quot;708&quot; /&gt;&lt;w:docGrid w:line-pitch=&quot;360&quot; /&gt;&lt;/w:sectPr&gt;&lt;/wx:sect&gt;&lt;/w:body&gt;&lt;/w:wordDocument&gt;">
							<v:imagedata src="wordml://03000002.png" o:title="" />
						</v:shape>
					</w:pict>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Times New Roman" w:fareast="Times New Roman" w:h-ansi="Times New Roman" w:cs="Times New Roman" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Times New Roman" w:fareast="Times New Roman" w:h-ansi="Times New Roman" w:cs="Times New Roman" />
						<w:sz w:val="24" />
						<w:sz-cs w:val="24" />
					</w:rPr>
				</w:pPr>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Analysis:</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>The temperature for the person with hot salsa rose from 33.3 to 34.8, and the person with medium salsa’s temperature rose from 34 to 35.6. Both peoples’ temperature rose after eating salsa.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Conclusion:</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
					<w:t>Eating spicy foods causes your internal temperature to rise, which in turn makes you sweat. From our data, we see that after consuming spicy salsa, the body temperature of the two test subjects rose around 1.5 degrees Celsius. However, it doesn't matter how spicy the food is because both subjects had about the same increase in temperature. </w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
					<w:t> </w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
					<w:t> </w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
					<w:t> </w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:lang w:val="EN-SG" />
					</w:rPr>
					<w:t> </w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Why did we use mild salsa as a control instead of using no food at all?</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Why do you suppose we took body temperatures under the arm instead of orally?</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Why do you suppose we had to measure body temperature before and after you ate salsa, rather than just after?  Consider experimental design.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Was your hypothesis supported?  Does this mean that it was proven correct?  Why or why not.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Can you think of any design flaws in this experiment (i.e., uncontrolled variables)?  If so, what are they?</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Did the results from this experiment make you think of new questions?  If so, what are they?</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Can you think of another hypothesis that was supported by the results other than the one we tried to test?  If so, what </w:t>
				</w:r>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>is(</w:t>
				</w:r>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>are) it(they)?</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t> </w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:listPr>
						<w:ilvl w:val="1" />
						<w:ilfo w:val="7" />
						<wx:t wx:val="1." />
						<wx:font wx:val="Calibri" />
					</w:listPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:textAlignment w:val="center" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>To see if spiciness affects temperature increase.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:listPr>
						<w:ilvl w:val="1" />
						<w:ilfo w:val="7" />
						<wx:t wx:val="2." />
						<wx:font wx:val="Calibri" />
					</w:listPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:textAlignment w:val="center" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Because orally, the saliva and the movement can create variables. And also for hygienic reasons. And also they'd be eating via mouth, and </w:t>
				</w:r>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>its</w:t>
				</w:r>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t> hard to eat with a metal stick in your mouth.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:listPr>
						<w:ilvl w:val="1" />
						<w:ilfo w:val="8" />
						<wx:t wx:val="3." />
						<wx:font wx:val="Calibri" />
					</w:listPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:textAlignment w:val="center" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>So that we had something to compare to.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:listPr>
						<w:ilvl w:val="1" />
						<w:ilfo w:val="9" />
						<wx:t wx:val="4." />
						<wx:font wx:val="Calibri" />
					</w:listPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:textAlignment w:val="center" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>It was correct according to the data I had collected.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:listPr>
						<w:ilvl w:val="1" />
						<w:ilfo w:val="9" />
						<wx:t wx:val="5." />
						<wx:font wx:val="Calibri" />
					</w:listPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:textAlignment w:val="center" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Why does your temperature rise? Why doesn't spicier salsa cause a faster or greater temperature increase?</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:listPr>
						<w:ilvl w:val="1" />
						<w:ilfo w:val="10" />
						<wx:t wx:val="6." />
						<wx:font wx:val="Calibri" />
					</w:listPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:ind w:left="497" />
					<w:textAlignment w:val="center" />
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
						<w:sz w:val="22" />
						<w:sz-cs w:val="22" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Spicy foods cause you to flush red.</w:t>
				</w:r>
			</w:p>
			<w:p>
				<w:pPr>
					<w:spacing w:before="0" w:after="0" w:line="240" w:line-rule="auto" />
					<w:rPr>
						<w:rFonts w:ascii="Times New Roman" w:fareast="Times New Roman" w:h-ansi="Times New Roman" w:cs="Times New Roman" />
						<w:sz w:val="24" />
						<w:sz-cs w:val="24" />
					</w:rPr>
				</w:pPr>
				<w:r>
					<w:rPr>
						<w:rFonts w:ascii="Times New Roman" w:fareast="Times New Roman" w:h-ansi="Times New Roman" w:cs="Times New Roman" />
						<w:sz w:val="24" />
						<w:sz-cs w:val="24" />
					</w:rPr>
					<w:t> </w:t>
				</w:r>
