						<w:rFonts w:ascii="Calibri" w:fareast="Times New Roman" w:h-ansi="Calibri" w:cs="Calibri" />
					</w:rPr>
					<w:t>Hypothesis: Spicy foods raise our internal temperature, which makes us sweat.</w:t>
				</w:r>
			</w:p>
