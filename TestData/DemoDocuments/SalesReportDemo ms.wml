		<wx:sub-section>
			<wx:sub-section>
				<wx:sub-section>
					<w:p wsp:rsidR="000D45E0" wsp:rsidRPr="00CC70D2" wsp:rsidRDefault="000D45E0" wsp:rsidP="000D45E0">
						<w:pPr>
							<w:pStyle w:val="Heading3" />
						</w:pPr>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t>Adventure Works Announces Quarterly Earnings </w:t>
						</w:r>
						<w:r wsp:rsidRPr="00AF688E">
							<w:t>Results</w:t>
						</w:r>
					</w:p>
					<w:p wsp:rsidR="000D45E0" wsp:rsidRPr="00CC70D2" wsp:rsidRDefault="000D45E0" wsp:rsidP="000D45E0">
						<w:pPr>
							<w:pStyle w:val="Subhead" />
						</w:pPr>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t>Earnings stronger than corresponding quarter for previous fiscal year.</w:t>
						</w:r>
					</w:p>
					<w:p wsp:rsidR="000D45E0" wsp:rsidRDefault="000D45E0" wsp:rsidP="000D45E0">
						<w:pPr>
							<w:pStyle w:val="Text" />
						</w:pPr>
						<w:r wsp:rsidRPr="005D115F">
							<w:rPr>
								<w:rStyle w:val="BoldTextChar" />
							</w:rPr>
							<w:t>Seattle, July 23, 200</w:t>
						</w:r>
						<w:r>
							<w:rPr>
								<w:rStyle w:val="BoldTextChar" />
							</w:rPr>
							<w:t>4</w:t>
						</w:r>
						<w:r wsp:rsidRPr="005D115F">
							<w:rPr>
								<w:rStyle w:val="BoldTextChar" />
							</w:rPr>
							<w:t>:</w:t>
						</w:r>
						<w:r>
							<w:rPr>
								<w:rStyle w:val="BoldTextChar" />
							</w:rPr>
							<w:t> </w:t>
						</w:r>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t> Adventure Works today announced net income of $1.2 million, or $.06 per share, for its sixteen-week fourth quarter of FY 200</w:t>
						</w:r>
						<w:r>
							<w:t>4</w:t>
						</w:r>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t> ended June 30, compared to a loss of $2.3 million, or $.57 per share for the </w:t>
						</w:r>
						<w:r>
							<w:t>last</w:t>
						</w:r>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t> quarter of </w:t>
						</w:r>
						<w:r>
							<w:t>FY </w:t>
						</w:r>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t>200</w:t>
						</w:r>
						<w:r>
							<w:t>3</w:t>
						</w:r>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t>. Sales were $48.1 million, a decrease from the $49.0 million reported for the </w:t>
						</w:r>
						<w:r>
							<w:t>same</w:t>
						</w:r>
						<w:r wsp:rsidRPr="00CC70D2">
							<w:t> quarter a year ago.</w:t>
						</w:r>
					</w:p>
					<w:p wsp:rsidR="000D45E0" wsp:rsidRPr="00CC70D2" wsp:rsidRDefault="000D45E0" wsp:rsidP="000D45E0">
						<w:pPr>
							<w:pStyle w:val="Text" />
						</w:pPr>
						<aml:annotation aml:id="0" w:type="Word.Bookmark.Start" w:name="SalesByCategory" />
