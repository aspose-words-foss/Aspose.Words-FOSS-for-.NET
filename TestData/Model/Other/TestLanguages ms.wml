	<w:body>
		<w:p wsp:rsidR="003B2F6F" wsp:rsidRPr="005955FF" wsp:rsidRDefault="005955FF">
			<w:pPr>
				<w:rPr>
					<w:rFonts w:ascii="Calibri" w:h-ansi="Calibri" w:cs="Calibri" />
