	<w:body>
		<w:p wsp:rsidR="003F173B" wsp:rsidRPr="00341B55" wsp:rsidRDefault="003F173B" wsp:rsidP="003F173B">
			<w:pPr>
				<w:rPr>
					<w:rFonts w:ascii="Times New Roman" w:h-ansi="Times New Roman" />
					<wx:font wx:val="Times New Roman" />
					<w:b w:val="off" />
					<w:sz w:val="24" />
				</w:rPr>
			</w:pPr>
			<w:r wsp:rsidRPr="00341B55">
				<w:rPr>
					<w:rFonts w:ascii="Times New Roman" w:h-ansi="Times New Roman" />
					<wx:font wx:val="Times New Roman" />
					<w:b w:val="off" />
					<w:sz w:val="24" />
				</w:rPr>
				<w:t>excuse me for a minute.”</w:t>
			</w:r>
		</w:p>
		<w:p wsp:rsidR="003F173B" wsp:rsidRPr="00341B55" wsp:rsidRDefault="003F173B" wsp:rsidP="003F173B">
			<w:pPr>
				<w:pStyle w:val="Hyperlink" />
				<w:rPr>
					<w:rFonts w:ascii="Times New Roman" w:h-ansi="Times New Roman" />
					<wx:font wx:val="Times New Roman" />
					<w:b w:val="off" />
					<w:sz w:val="24" />
					<w:lang w:fareast="JA" />
				</w:rPr>
			</w:pPr>
			<w:r wsp:rsidRPr="00341B55">
				<w:rPr>
					<w:rFonts w:ascii="Times New Roman" w:h-ansi="Times New Roman" />
					<wx:font wx:val="Times New Roman" />
					<w:b w:val="off" />
					<w:sz w:val="24" />
				</w:rPr>
				<w:tab />
				<w:t>On the porch Charles and the cowboy talked for a few minutes before the cowboy left.  When Charles came back in </w:t>
			</w:r>
			<w:r wsp:rsidRPr="00341B55">
				<w:rPr>
					<w:rFonts w:ascii="Times New Roman" w:h-ansi="Times New Roman" />
					<wx:font wx:val="Times New Roman" />
					<w:b w:val="off" />
					<w:sz w:val="24" />
					<w:lang w:fareast="JA" />
				</w:rPr>
				<w:t>Josie was curious, but she felt it was safer to not ask any questions.</w:t>
			</w:r>
		</w:p>
		<w:p wsp:rsidR="003F173B" wsp:rsidRPr="00341B55" wsp:rsidRDefault="003F173B" wsp:rsidP="003F173B">
			<w:pPr>
				<w:pStyle w:val="Hyperlink" />
				<w:rPr>
					<w:rFonts w:ascii="Times New Roman" w:h-ansi="Times New Roman" />
					<wx:font wx:val="Times New Roman" />
					<w:b w:val="off" />
					<w:sz w:val="24" />
					<w:lang w:fareast="JA" />
				</w:rPr>
			</w:pPr>
			<w:r wsp:rsidRPr="00341B55">
				<w:rPr>
