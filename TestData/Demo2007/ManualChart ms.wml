	<w:body>
		<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
			<w:pPr>
				<w:widowControl w:val="off" />
				<w:jc w:val="center" />
			</w:pPr>
			<w:r>
				<w:rPr>
					<w:noProof />
					<w:lang w:fareast="ZH-CN" />
				</w:rPr>
				<w:pict>
					<v:shapetype id="_x0000_t202" coordsize="21600,21600" o:spt="202" path="m,l,21600r21600,l21600,xe">
						<v:stroke joinstyle="miter" />
						<v:path gradientshapeok="t" o:connecttype="rect" />
					</v:shapetype>
					<v:shape id="_x0000_s1056" type="#_x0000_t202" style="position:absolute;left:0;text-align:left;margin-left:-28.05pt;margin-top:20.15pt;width:504.9pt;height:149.6pt;z-index:2" filled="f" stroked="f">
						<v:textbox>
							<w:txbxContent>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
									</w:pPr>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>Hints</w:t>
									</w:r>
								</w:p>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:listPr>
											<w:ilvl w:val="0" />
											<w:ilfo w:val="1" />
											<wx:t wx:val="·" />
											<wx:font wx:val="Symbol" />
										</w:listPr>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
									</w:pPr>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>To create a flowchart, you can modify this example or you can start from scratch to create your own flowchart.</w:t>
									</w:r>
								</w:p>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:listPr>
											<w:ilvl w:val="0" />
											<w:ilfo w:val="1" />
											<wx:t wx:val="·" />
											<wx:font wx:val="Symbol" />
										</w:listPr>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
									</w:pPr>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>To delete the sample TQM flowchart, select the flowchart and press DELETE.</w:t>
									</w:r>
								</w:p>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
									</w:pPr>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>To add flowchart shapes</w:t>
									</w:r>
								</w:p>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:listPr>
											<w:ilvl w:val="0" />
											<w:ilfo w:val="6" />
											<wx:t wx:val="·" />
											<wx:font wx:val="Symbol" />
										</w:listPr>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
									</w:pPr>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>On the </w:t>
									</w:r>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:b-cs />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>Flow Shapes</w:t>
									</w:r>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b-cs />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t> toolbar</w:t>
									</w:r>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>, click the shape you want, and then click where you want to draw the flowchart shape.</w:t>
									</w:r>
								</w:p>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
									</w:pPr>
									<w:r>
										<w:rPr>
											<w:rFonts w:ascii="Arial" w:h-ansi="Arial" w:cs="Arial" />
											<wx:font wx:val="Arial" />
											<w:b />
											<w:sz w:val="20" />
											<w:sz-cs w:val="20" />
										</w:rPr>
										<w:t>To add connectors between the shapes</w:t>
									</w:r>
								</w:p>
								<w:p wsp:rsidR="0089697B" wsp:rsidRDefault="0089697B">
									<w:pPr>
										<w:listPr>
											<w:ilvl w:val="1" />
											<w:ilfo w:val="6" />
											<wx:t wx:val="1." />
											<wx:font wx:val="Times New Roman" />
										</w:listPr>
										<w:tabs>
											<w:tab w:val="clear" w:pos="1440" />
											<w:tab w:val="list" w:pos="374" />
										</w:tabs>
										<w:ind w:left="374" w:hanging="374" />
										<w:rPr>
