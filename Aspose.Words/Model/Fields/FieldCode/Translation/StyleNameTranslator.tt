<#@ template debug="false" hostspecific="true" language="C#" #>
<#@ assembly name="System.Core" #>
<#@ assembly name="System.Xml"#>
<#@ import namespace="System.IO" #>
<#@ import namespace="System.Collections.Generic" #>
<#@ import namespace="System.Xml" #>
<#@ output extension=".cs" #>
<#
string directory = Path.GetDirectoryName(Host.TemplateFile);
string file = Path.Combine(directory, "StyleNameTranslation.xml");
XmlDocument doc = new XmlDocument();
doc.Load(file);
List<Language> languages = new List<Language>();
Language defaultLanguage = null;
foreach (XmlNode languageNode in doc.DocumentElement.ChildNodes)
{
	string languageName = languageNode.Attributes["name"]?.Value;
	if (string.IsNullOrEmpty(languageName))
		throw new Exception("language name is not specified");
	Language language = new Language();
	language.Name = languageName;
	foreach (XmlNode styleNode in languageNode.ChildNodes)
	{
		string styleName = styleNode.Attributes["name"]?.Value;
		if (string.IsNullOrEmpty(styleName))
			throw new Exception("style name is not specified");
		language.Styles.Add(styleName);
	}
	
	if (languageNode.Attributes["default"] != null)
		defaultLanguage = language;
	else
		languages.Add(language);
}
if (defaultLanguage == null)	
	throw new Exception("default language is not specified");
 #>
